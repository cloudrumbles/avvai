{
  "id": "cikaram-1-9",
  "title": "Unfolding Bud",
  "titleTamil": "உயர்நிலைத்திறன்",
  "chapter": 1,
  "section": 9,
  "cards": [
    {
      "type": "poetry",
      "title": "Unfolding Bud",
      "lines": [
        "One is amazed",
        "By a water-lily",
        "Unfolding",
        "With each passing day,",
        "Taking on a richer colour",
        "And new dimensions",
        "",
        "One is not amazed",
        "At a first glance,",
        "By a poem",
        "Which is as tight-closed",
        "As a tiny bud",
        "",
        "Yet one is surprised",
        "To see the poem",
        "Gradually unfolding,",
        "Revealing its rich inner self,",
        "As one reads it",
        "Again",
        "And over again."
      ],
      "source": "Naoshi Koriyama"
    }
  ]
}
